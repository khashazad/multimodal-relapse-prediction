{
    "_description": "CNN+LSTM joint end-to-end training (all 5 modality branches)",
    "fold": [0, 1, 2, 3, 4, 5, 6, 7, 8],
    "cnn_hidden_1": 32,
    "cnn_hidden_2": 16,
    "lstm_hidden": 16,
    "fc_hidden": 16,
    "cnn_kernel": 5,
    "cnn_dropout": 0.5,
    "lstm_dropout": 0.3,
    "fc_dropout": 0.3,
    "fusion": "learned",
    "lr": 1e-3,
    "weight_decay": 0.01,
    "batch_size": 32,
    "epochs": 100,
    "patience": 15,
    "loss_fn": "focal",
    "focal_alpha": 0.7,
    "focal_gamma": 1.0,
    "seed": 42,
    "threshold": 0.5,
    "data_dir": "data/processed_cnn/track1",
    "calibrate_threshold": true,
    "augmentation": "none",
    "scheduler": "cosine",
    "warmup_epochs": 0,
    "early_stop_metric": "auroc",
    "label_smoothing": 0.0,
    "executor": {
        "exec_name": "train_cnn",
        "output_dir": "outputs",
        "log_dir": "outputs/logs"
    },
    "slurm": {
        "cores": 4,
        "nodes": 1,
        "time": "0-02:00",
        "memory": "16G",
        "partition": "gpunodes",
        "account": "",
        "email": "Khashayar1924@gmail.com",
        "email_type": "END,FAIL",
        "log_dir": "outputs/slurm_logs",
        "job_name": "cnn_lstm_joint",
        "exclude": "",
        "constraint": "",
        "gres": "gpu:rtx_4090:1",
        "julia_path": ""
    }
}
