{
    "_description": "TTA on transformer checkpoints. 9 folds x 2 feature_sets x 2 variants x 2 lrs = 72 jobs. +18 renorm jobs = 90 total.",
    "method": "tta",
    "fold": [0, 1, 2, 3, 4, 5, 6, 7, 8],
    "feature_set": ["union", "all"],
    "tta_variant": ["entropy_ln", "feature_renorm"],
    "tta_lr": [1e-4, 1e-3],
    "tta_alpha": 0.3,
    "tta_steps": 10,
    "base_d_model": 1024,
    "seq_len": 7,
    "batch_size": 32,
    "lr": 1e-3,
    "n_epochs": 80,
    "seed": 42,
    "data_path": "data/processed/patient_data_export_all9.pkl",
    "executor": {
        "exec_name": "ensemble_phase",
        "output_dir": "outputs/ensemble_phase",
        "log_dir": "outputs/ensemble_phase/logs"
    },
    "slurm": {
        "cores": 4,
        "nodes": 1,
        "time": "0-00:15",
        "memory": "4G",
        "partition": "gpunodes",
        "gres": "gpu:1",
        "job_name": "ens_tta",
        "exclude": "gpunode13",
        "log_dir": "outputs/slurm_logs"
    }
}
