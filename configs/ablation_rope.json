{
    "_description": "Ablation Stage 4: RoPE (Rotary Position Embedding). 9 folds x 1 = 9 jobs.",
    "method": "feature_exp",
    "fold": [0, 1, 2, 3, 4, 5, 6, 7, 8],
    "feature_set": "all",
    "d_model": 1024,
    "n_layers": 3,
    "dropout": 0.3,
    "nhead": 4,
    "seq_len": 7,
    "batch_size": 32,
    "lr": 1e-3,
    "n_epochs": 80,
    "seed": 42,
    "data_path": "data/processed/patient_data_export_all9.pkl",
    "use_rope": true,
    "executor": {
        "exec_name": "ablation",
        "output_dir": "outputs/ablations",
        "log_dir": "outputs/ablations/logs"
    },
    "slurm": {
        "cores": 4,
        "nodes": 1,
        "time": "0-04:00",
        "memory": "4G",
        "partition": "gpunodes",
        "account": "",
        "email": "",
        "email_type": "END,FAIL",
        "log_dir": "outputs/slurm_logs",
        "job_name": "abl_rope",
        "exclude": "gpunode13",
        "constraint": "",
        "gres": "gpu:1",
        "julia_path": ""
    }
}
